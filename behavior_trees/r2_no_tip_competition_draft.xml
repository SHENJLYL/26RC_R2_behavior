<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <!--
    R2 no-tip competition draft.

    Purpose:
      This draft describes the competition flow after deciding not to execute the
      tip pickup and weapon assembly task. It intentionally keeps unimplemented
      interfaces as placeholder BT nodes so later action/service wrappers can be
      connected without changing the mission semantics.

    Runtime note:
      The current r2_behavior_server only registers:
        IsManualStart, NavigateToNamedPose, PubNav2Goal, PublishTwist.
      This file is safe for the server to scan because future interfaces are
      represented by AlwaysFailure placeholders. Do not use
      target_tree:=R2_NoTip_Competition_Main as a mission tree until those
      placeholders are replaced by registered wrappers.
  -->

  <BehaviorTree ID="StopAllMotion">
    <Sequence>
      <PublishTwist topic_name="cmd_vel"
                    duration="0"
                    v_x="0.0"
                    v_y="0.0"
                    v_yaw="0.0"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_PreMatchAndStart">
    <Sequence>
      <!-- TODO service/action: /r2/health/check_start_ready -->
      <AlwaysFailure name="HealthCheckStartReadyPlaceholder"/>

      <!-- Existing node: start when /manual_start >= 1. -->
      <IsManualStart key_port="{@manual_start}"
                     start_value="1"/>

      <!-- Strategy decision: skip the tip pickup and weapon assembly task. -->
      <AlwaysSuccess name="SkipTipPickupAndWeaponAssemblyByStrategy"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_MoveToMFBoundaryAndWait">
    <Sequence>
      <!-- Existing node: navigate to the MC/MF boundary standby pose. -->
      <RetryUntilSuccessful num_attempts="2">
        <NavigateToNamedPose target="mc_mf_boundary_standoff"
                             team_side="{team_side}"
                             timeout_sec="45.0"/>
      </RetryUntilSuccessful>

      <SubTree ID="StopAllMotion"/>

      <!--
        TODO condition/action:
          - success when match elapsed time reaches 120 seconds, or
          - success when the R1 ArUco instruction explicitly permits continuing.
        This stage treats R1 as already in MF after the condition succeeds.
      -->
      <Fallback name="WaitElapsedOrR1CodeForMFEntry">
        <AlwaysFailure name="MatchElapsedReached120SecPlaceholder"/>
        <AlwaysFailure name="ReadArUcoInstruction_R1EnteredMFOrContinueToMF_Placeholder"/>
      </Fallback>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_EnterMFWithRecovery">
    <Fallback name="EnterMFOrCodeRecovery">
      <Sequence name="NormalEnterMF">
        <NavigateToNamedPose target="forest_entry_block_2_standoff"
                             team_side="{team_side}"
                             timeout_sec="60.0"/>
        <AlwaysFailure name="SetTravelModeForestPlaceholder"/>
        <AlwaysFailure name="ConfirmChassisLiftAndForestModePlaceholder"/>
      </Sequence>

      <Sequence name="ArucoContinueRecovery">
        <SubTree ID="StopAllMotion"/>
        <AlwaysFailure name="ReadArUcoInstruction_ContinueToMF_Placeholder"/>
        <RetryUntilSuccessful num_attempts="2">
          <NavigateToNamedPose target="forest_entry_block_2_standoff"
                               team_side="{team_side}"
                               timeout_sec="45.0"/>
        </RetryUntilSuccessful>
        <AlwaysFailure name="SetTravelModeForestRecoveryPlaceholder"/>
        <AlwaysFailure name="ConfirmChassisLiftAndForestModeRecoveryPlaceholder"/>
      </Sequence>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_ForestPlanAndExecute">
    <Sequence>
      <!--
        TODO topic/action bridge:
          Current web tool publishes web_spoiler/msg/WebSpoiler on /kfs_locator/state.
          Later this should become a locked unified /r2/perception/kfs_map.
      -->
      <AlwaysFailure name="WaitForManualKFSMapPlaceholder"/>

      <!-- TODO service/action wrapper around meilin_router router(topic1 -> topic2). -->
      <AlwaysFailure name="RequestForestPlanPlaceholder"/>

      <!--
        TODO state manager:
          Preserve initial_kfs_map, current_kfs_map, removed_r2_blocks,
          current_block, current_step_index and carrying_payload.
      -->
      <AlwaysFailure name="InitializeForestMapStatePlaceholder"/>

      <!--
        TODO custom decorator/action:
          Executes ForestSteps in order. For each step:
            1. Validate expected KFS on target block once with arm-camera vision service.
            2. For MOVE, confirm R1 KFS blocking state by camera if the planner marks one.
            3. If camera still sees R1 KFS present, wait for removal and delay briefly.
            4. Execute adjacent-block motion with lift/lidar confirmation.
            5. For PICK, use arm camera + suction action to pick only R2 KFS.
            6. For PLACE, place current payload temporarily and update state.
            7. Update removed_r2_blocks and current_kfs_map after each result.
      -->
      <RetryUntilSuccessful num_attempts="2">
        <AlwaysFailure name="ExecuteForestPlanPlaceholder"/>
      </RetryUntilSuccessful>

      <AlwaysFailure name="RequirePayloadR2KFSPlaceholder"/>
      <AlwaysFailure name="ExitForestViaBlock10_11_12Placeholder"/>
      <AlwaysFailure name="SetTravelModeGroundPlaceholder"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_BattlefieldGridPlacement">
    <Sequence>
      <NavigateToNamedPose target="battlefield_grid_standoff"
                           team_side="{team_side}"
                           timeout_sec="90.0"/>

      <SubTree ID="StopAllMotion"/>

      <!-- Wait until R1 manual operation has aligned R1/R2 at the grid. -->
      <AlwaysFailure name="ReadArUcoInstruction_R1GridAlignReady_Placeholder"/>

      <!-- TODO action: README mentions AlignToR1, but the action file is not present yet. -->
      <AlwaysFailure name="AlignToR1ForClimbPlaceholder"/>

      <!-- Climb onto R1 or the R1-supported position. -->
      <RetryUntilSuccessful num_attempts="2">
        <AlwaysFailure name="UpStairsActionOntoR1Placeholder"/>
      </RetryUntilSuccessful>
      <AlwaysFailure name="ConfirmChassisLiftOnR1Placeholder"/>

      <!-- R1 code selects the rack layer. Layer 2 exists in PlaceKFS.action;
           layer 3 still needs interface extension or a dedicated task action. -->
      <Fallback name="PlaceByR1LayerCode">
        <Sequence name="PlaceOnLayer2">
          <AlwaysFailure name="ReadArUcoInstruction_PlaceGridLayer2_Placeholder"/>
          <AlwaysFailure name="PlaceKFSOnGridLayer2Placeholder"/>
        </Sequence>

        <Sequence name="PlaceOnLayer3">
          <AlwaysFailure name="ReadArUcoInstruction_PlaceGridLayer3_Placeholder"/>
          <AlwaysFailure name="PlaceKFSOnGridLayer3Placeholder"/>
        </Sequence>
      </Fallback>

      <AlwaysFailure name="RequirePayloadNonePlaceholder"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="NoTip_RetryRecovery">
    <Sequence>
      <!-- TODO topic/service: /r2/retry/request + current zone/payload/map state. -->
      <AlwaysFailure name="IsRetryRequestedPlaceholder"/>
      <SubTree ID="StopAllMotion"/>
      <AlwaysFailure name="ExecuteAreaAwareRetryPlaceholder"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="R2_NoTip_Competition_Main">
    <ReactiveFallback name="R2NoTipRoot">
      <Sequence name="EmergencyStopBranch">
        <!-- TODO topic: /r2/safety/emergency_stop_state -->
        <AlwaysFailure name="IsEmergencyStopRequestedPlaceholder"/>
        <SubTree ID="StopAllMotion"/>
      </Sequence>

      <SubTree ID="NoTip_RetryRecovery"/>

      <Sequence name="NoTipCompetitionMission">
        <SubTree ID="NoTip_PreMatchAndStart"/>
        <SubTree ID="NoTip_MoveToMFBoundaryAndWait"/>
        <SubTree ID="NoTip_EnterMFWithRecovery"/>
        <SubTree ID="NoTip_ForestPlanAndExecute"/>
        <SubTree ID="NoTip_BattlefieldGridPlacement"/>
        <SubTree ID="StopAllMotion"/>
      </Sequence>
    </ReactiveFallback>
  </BehaviorTree>
</root>
