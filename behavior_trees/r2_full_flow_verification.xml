<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="Flow_StopAllMotion">
    <Sequence>
      <PublishTwist topic_name="cmd_vel"
                    duration="0"
                    v_x="0.0"
                    v_y="0.0"
                    v_yaw="0.0"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Flow_PreMatchAndStart_NoTip">
    <Sequence>
      <AlwaysSuccess name="PreMatchSelfCheckMock"/>
      <IsManualStart key_port="{@manual_start}"
                     start_value="1"/>
      <AlwaysSuccess name="SkipTipPickupAndWeaponAssemblyMock"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Flow_MC_WaitAtMFBoundary">
    <Sequence>
      <AlwaysSuccess name="NavigateToMC_MFBoundaryMock"/>
      <SubTree ID="Flow_StopAllMotion"/>
      <AlwaysSuccess name="Wait120SecOrReadArUcoContinueMock"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Flow_MF_EnterForestEntry">
    <Sequence>
      <AlwaysSuccess name="NavigateToForestEntryBlock2Mock"/>
      <AlwaysSuccess name="SetTravelModeForestMock"/>
      <AlwaysSuccess name="ConfirmLiftByScrewAndLidarMock"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Flow_MF_ExecuteForestPlan">
    <Sequence>
      <AlwaysSuccess name="WaitKFSLocatorStateMock"/>
      <AlwaysSuccess name="RequestMeilinRouterPlanMock"/>
      <AlwaysSuccess name="InitializeForestMapStateMock"/>
      <AlwaysSuccess name="ValidateKFSOnBlockArmCameraMock"/>
      <AlwaysSuccess name="WaitR1KFSRemovedByCameraIfNeededMock"/>
      <AlwaysSuccess name="ExecuteForestStepsMock"/>
      <AlwaysSuccess name="RecordRemovedR2KFSBlocksMock"/>
      <AlwaysSuccess name="ExitForestViaBlock10_11_12Mock"/>
      <AlwaysSuccess name="SetTravelModeGroundMock"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="Flow_Battlefield_ClimbAndPlaceKFS">
    <Sequence>
      <AlwaysSuccess name="NavigateToBattlefieldGridStandoffMock"/>
      <SubTree ID="Flow_StopAllMotion"/>
      <AlwaysSuccess name="ReadArUcoGridAlignReadyMock"/>
      <AlwaysSuccess name="AlignToR1ForClimbMock"/>
      <AlwaysSuccess name="UpStairsOntoR1Mock"/>
      <AlwaysSuccess name="ReadArUcoLayerCodeMock"/>
      <AlwaysSuccess name="PlaceKFSOnGridLayer2Or3Mock"/>
      <AlwaysSuccess name="ConfirmPayloadNoneMock"/>
    </Sequence>
  </BehaviorTree>

  <BehaviorTree ID="R2_Full_Flow_Verification">
    <ReactiveFallback name="R2FlowVerificationRoot">
      <Sequence name="EmergencyStopBranchMockedInactive">
        <AlwaysFailure name="IsEmergencyStopRequestedMock"/>
        <SubTree ID="Flow_StopAllMotion"/>
      </Sequence>

      <Sequence name="RetryRecoveryBranchMockedInactive">
        <AlwaysFailure name="IsRetryRequestedMock"/>
        <AlwaysSuccess name="ExecuteAreaAwareRetryMock"/>
      </Sequence>

      <Sequence name="CompetitionMissionNoTipFlow">
        <SubTree ID="Flow_PreMatchAndStart_NoTip"/>
        <SubTree ID="Flow_MC_WaitAtMFBoundary"/>
        <SubTree ID="Flow_MF_EnterForestEntry"/>
        <SubTree ID="Flow_MF_ExecuteForestPlan"/>
        <SubTree ID="Flow_Battlefield_ClimbAndPlaceKFS"/>
        <SubTree ID="Flow_StopAllMotion"/>
      </Sequence>
    </ReactiveFallback>
  </BehaviorTree>
</root>
